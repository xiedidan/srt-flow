# SRT Flow Environment Configuration

# Server
HOST=0.0.0.0
PORT=8010
DEBUG=false

# Database
DATABASE_PATH=data/srtflow.db

# File Storage
DATA_DIR=data
DOWNLOADS_DIR=data/downloads

# Security
SECRET_KEY=your-secret-key-change-in-production
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Logging
LOG_LEVEL=INFO
LOG_DIR=data/logs

# External Tools
FFMPEG_PATH=ffmpeg
YTDLP_PATH=yt-dlp

# Optional: GPU Settings
CUDA_VISIBLE_DEVICES=0
