# SRT Flow - Docker Ignore File
# Copy to project root when building

# Git
.git
.gitignore

# IDE
.vscode
.idea
*.swp
*.swo

# Python
__pycache__
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
.env.local
*.egg-info/
.eggs/
dist/
build/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Data (mounted as volume)
data/
*.db
*.sqlite

# Logs
*.log
logs/

# Documentation (not needed in container)
docs/
tasks/
*.md
!README.md

# Tests
tests/
*_test.py
test_*.py
.pytest_cache/
.coverage
htmlcov/

# Temporary files
*.tmp
*.temp
.DS_Store
Thumbs.db

# Deploy files (except what's needed)
deploy/.env
deploy/.env.local
