# SRT Flow - Docker Environment Configuration
# Copy this file to .env and modify as needed

# =============================================================================
# Server Configuration
# =============================================================================
HOST=0.0.0.0
PORT=8010
DEBUG=false

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_PATH=/app/data/srtflow.db

# =============================================================================
# File Storage
# =============================================================================
DATA_DIR=/app/data
DOWNLOADS_DIR=/app/data/downloads
LOG_DIR=/app/data/logs

# =============================================================================
# Security
# =============================================================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key

# 32-byte key for AES-256 encryption
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=change-this-to-a-32-byte-hex-key

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# External Tools
# =============================================================================
FFMPEG_PATH=ffmpeg
YTDLP_PATH=yt-dlp

# =============================================================================
# GPU Settings (for GPU-enabled deployment)
# =============================================================================
# Specify which GPU to use (0, 1, etc. or "all")
CUDA_VISIBLE_DEVICES=0

# =============================================================================
# Optional: API Keys (stored encrypted in database, not here)
# These are just for reference - configure via web UI
# =============================================================================
# OPENAI_API_KEY=sk-xxx
# DEEPSEEK_API_KEY=sk-xxx
# GEMINI_API_KEY=xxx
